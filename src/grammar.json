{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "bgmax",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "starting_record"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "section"
          }
        },
        {
          "type": "SYMBOL",
          "name": "end_record"
        }
      ]
    },
    "starting_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "01"
        },
        {
          "type": "SYMBOL",
          "name": "layout_name"
        },
        {
          "type": "SYMBOL",
          "name": "layout_version"
        },
        {
          "type": "SYMBOL",
          "name": "creation_timestamp"
        },
        {
          "type": "SYMBOL",
          "name": "test_indicator"
        },
        {
          "type": "PATTERN",
          "value": " {35}"
        }
      ]
    },
    "layout_name": {
      "type": "PATTERN",
      "value": ".{20}"
    },
    "layout_version": {
      "type": "PATTERN",
      "value": ".{2}"
    },
    "creation_timestamp": {
      "type": "PATTERN",
      "value": "[0-9]{20}"
    },
    "test_indicator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "T"
        },
        {
          "type": "STRING",
          "value": "P"
        }
      ]
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "opening_record"
        },
        {
          "type": "SYMBOL",
          "name": "catch_all_lines"
        },
        {
          "type": "SYMBOL",
          "name": "deposit_record"
        }
      ]
    },
    "currency_code": {
      "type": "PATTERN",
      "value": "[ A-Z]{3}"
    },
    "opening_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "05"
        },
        {
          "type": "SYMBOL",
          "name": "payee_bankgiro_number"
        },
        {
          "type": "SYMBOL",
          "name": "payee_plusgiro_number"
        },
        {
          "type": "SYMBOL",
          "name": "currency_code"
        },
        {
          "type": "PATTERN",
          "value": " {55}"
        }
      ]
    },
    "payee_bankgiro_number": {
      "type": "PATTERN",
      "value": "[0-9]{10}"
    },
    "payee_plusgiro_number": {
      "type": "PATTERN",
      "value": "[ a-zA-Z0-9]{10}"
    },
    "deposit_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "15"
        },
        {
          "type": "SYMBOL",
          "name": "payee_bank_account_number"
        },
        {
          "type": "SYMBOL",
          "name": "payment_date"
        },
        {
          "type": "SYMBOL",
          "name": "deposit_serial_number"
        },
        {
          "type": "SYMBOL",
          "name": "deposit_amount"
        },
        {
          "type": "SYMBOL",
          "name": "currency_code"
        },
        {
          "type": "FIELD",
          "name": "number_of_payments",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "SYMBOL",
          "name": "type_of_deposit"
        }
      ]
    },
    "payee_bank_account_number": {
      "type": "PATTERN",
      "value": "[0-9]{35}"
    },
    "payment_date": {
      "type": "PATTERN",
      "value": "[0-9]{8}"
    },
    "deposit_serial_number": {
      "type": "PATTERN",
      "value": "[0-9]{5}"
    },
    "deposit_amount": {
      "type": "PATTERN",
      "value": "[0-9]{18}"
    },
    "type_of_deposit": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "K"
        },
        {
          "type": "STRING",
          "value": "D"
        },
        {
          "type": "STRING",
          "value": " "
        }
      ]
    },
    "end_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "70"
        },
        {
          "type": "FIELD",
          "name": "number_of_payment_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_deduction_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_extra_reference_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_deposit_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "PATTERN",
          "value": " {46}"
        }
      ]
    },
    "number_of": {
      "type": "PATTERN",
      "value": "[0-9]{8}"
    },
    "catch_all_lines": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "catch_all"
      }
    },
    "catch_all": {
      "type": "PATTERN",
      "value": "2[0-9].{78}"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}