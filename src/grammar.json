{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "bgmax",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "file_opening_record"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "section"
          }
        },
        {
          "type": "SYMBOL",
          "name": "file_end_record"
        }
      ]
    },
    "file_opening_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "01"
        },
        {
          "type": "SYMBOL",
          "name": "layout_name"
        },
        {
          "type": "SYMBOL",
          "name": "layout_version"
        },
        {
          "type": "SYMBOL",
          "name": "creation_timestamp"
        },
        {
          "type": "SYMBOL",
          "name": "test_indicator"
        },
        {
          "type": "PATTERN",
          "value": " {35}"
        }
      ]
    },
    "layout_name": {
      "type": "PATTERN",
      "value": ".{20}"
    },
    "layout_version": {
      "type": "PATTERN",
      "value": ".{2}"
    },
    "creation_timestamp": {
      "type": "PATTERN",
      "value": "[0-9]{20}"
    },
    "test_indicator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "T"
        },
        {
          "type": "STRING",
          "value": "P"
        }
      ]
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_opening_record"
        },
        {
          "type": "SYMBOL",
          "name": "catch_all_lines"
        },
        {
          "type": "SYMBOL",
          "name": "section_deposit_record"
        }
      ]
    },
    "currency_code": {
      "type": "PATTERN",
      "value": "[ A-Z]{3}"
    },
    "section_opening_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "05"
        },
        {
          "type": "FIELD",
          "name": "payee_bankgiro_number",
          "content": {
            "type": "SYMBOL",
            "name": "bankgiro_number"
          }
        },
        {
          "type": "SYMBOL",
          "name": "payee_plusgiro_number"
        },
        {
          "type": "SYMBOL",
          "name": "currency_code"
        },
        {
          "type": "PATTERN",
          "value": " {55}"
        }
      ]
    },
    "bankgiro_number": {
      "type": "PATTERN",
      "value": "[0-9]{10}"
    },
    "section_deposit_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "15"
        },
        {
          "type": "SYMBOL",
          "name": "payee_bank_account_number"
        },
        {
          "type": "SYMBOL",
          "name": "payment_date"
        },
        {
          "type": "SYMBOL",
          "name": "deposit_serial_number"
        },
        {
          "type": "FIELD",
          "name": "deposit_amount",
          "content": {
            "type": "SYMBOL",
            "name": "amount"
          }
        },
        {
          "type": "SYMBOL",
          "name": "currency_code"
        },
        {
          "type": "FIELD",
          "name": "number_of_payments",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "SYMBOL",
          "name": "type_of_deposit"
        }
      ]
    },
    "payee_bank_account_number": {
      "type": "PATTERN",
      "value": "[0-9]{35}"
    },
    "payment_date": {
      "type": "PATTERN",
      "value": "[0-9]{8}"
    },
    "deposit_serial_number": {
      "type": "PATTERN",
      "value": "[0-9]{5}"
    },
    "amount": {
      "type": "PATTERN",
      "value": "[0-9]{18}"
    },
    "type_of_deposit": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "K"
        },
        {
          "type": "STRING",
          "value": "D"
        },
        {
          "type": "STRING",
          "value": " "
        }
      ]
    },
    "file_end_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "70"
        },
        {
          "type": "FIELD",
          "name": "number_of_payment_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_deduction_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_extra_reference_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "FIELD",
          "name": "number_of_deposit_records",
          "content": {
            "type": "SYMBOL",
            "name": "number_of"
          }
        },
        {
          "type": "PATTERN",
          "value": " {46}"
        }
      ]
    },
    "number_of": {
      "type": "PATTERN",
      "value": "[0-9]{8}"
    },
    "single_digit_code": {
      "type": "PATTERN",
      "value": "[0-9]{1}"
    },
    "bgc_serial_number": {
      "type": "PATTERN",
      "value": "[0-9]{12}"
    },
    "payment_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "20"
        },
        {
          "type": "FIELD",
          "name": "payer_bankgiro_number",
          "content": {
            "type": "SYMBOL",
            "name": "bankgiro_number"
          }
        },
        {
          "type": "SYMBOL",
          "name": "reference"
        },
        {
          "type": "FIELD",
          "name": "payment_amount",
          "content": {
            "type": "SYMBOL",
            "name": "amount"
          }
        },
        {
          "type": "FIELD",
          "name": "reference_code",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "FIELD",
          "name": "payment_channel_code",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "SYMBOL",
          "name": "bgc_serial_number"
        },
        {
          "type": "FIELD",
          "name": "image_marking",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "PATTERN",
          "value": " {10}"
        }
      ]
    },
    "deduction_record": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "21"
        },
        {
          "type": "FIELD",
          "name": "payer_bankgiro_number",
          "content": {
            "type": "SYMBOL",
            "name": "bankgiro_number"
          }
        },
        {
          "type": "SYMBOL",
          "name": "reference"
        },
        {
          "type": "FIELD",
          "name": "payment_amount",
          "content": {
            "type": "SYMBOL",
            "name": "amount"
          }
        },
        {
          "type": "FIELD",
          "name": "reference_code",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "FIELD",
          "name": "payment_channel_code",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "SYMBOL",
          "name": "bgc_serial_number"
        },
        {
          "type": "FIELD",
          "name": "image_marking",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "FIELD",
          "name": "deduction_code",
          "content": {
            "type": "SYMBOL",
            "name": "single_digit_code"
          }
        },
        {
          "type": "PATTERN",
          "value": " {9}"
        }
      ]
    },
    "catch_all_lines": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "payment_record"
          },
          {
            "type": "SYMBOL",
            "name": "deduction_record"
          },
          {
            "type": "SYMBOL",
            "name": "catch_all"
          }
        ]
      }
    },
    "catch_all": {
      "type": "PATTERN",
      "value": "2[2-9].{78}"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "payee_plusgiro_number"
    },
    {
      "type": "SYMBOL",
      "name": "reference"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}